{
  "name": "confcall-scheduler",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run db:up && npm run db:push && npm run build:be && npm run start:be",
    "dev:fe": "npm --prefix frontend start -- --proxy-config proxy.conf.json",
    "dev:be": "npm run db:up && npm run db:push && npm run build:be && npm run start:be",
    "build:fe": "npm --prefix frontend run build",
    "build:be": "tsc -p server/tsconfig.build.json",
    "build": "npm run build:fe && npm run build:be",
    "start": "node server/dist/server/src/main.js",
    "start:be": "node server/dist/server/src/main.js",
    "check": "tsc -p server/tsconfig.build.json --noEmit && npm --prefix frontend run build -- --configuration development",
    "format": "prettier --write .",
    "e2e": "playwright test",
    "a11y": "playwright test e2e/accessibility.spec.ts --project=chromium",
    "ui:screenshot": "playwright test e2e/screenshots.spec.ts --project=chromium",
    "ui:screenshot:docker": "docker compose run --rm playwright npm run ui:screenshot",
    "db:up": "docker compose up -d mysql",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f mysql",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@angular/cdk": "^19.2.19",
    "@angular/common": "^19.2.22",
    "@angular/compiler": "^19.2.22",
    "@angular/core": "^19.2.22",
    "@angular/forms": "^19.2.22",
    "@angular/platform-browser": "^19.2.22",
    "@angular/platform-browser-dynamic": "^19.2.22",
    "@angular/router": "^19.2.22",
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@types/nodemailer": "^8.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.1",
    "flatpickr": "^4.6.13",
    "mysql2": "^3.14.1",
    "nanoid": "^5.1.11",
    "nodemailer": "^9.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "superjson": "^2.2.6",
    "zod": "^4.4.3",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.5.1",
    "@angular-devkit/build-angular": "^19.2.22",
    "@angular/build": "^19.2.22",
    "@angular/cli": "^19.2.22",
    "@angular/compiler-cli": "^19.2.22",
    "@axe-core/playwright": "^4.11.3",
    "@nestjs/cli": "^11.0.0",
    "@playwright/test": "^1.60.0",
    "@types/express": "^5.0.0",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-react": "^5.1.1",
    "drizzle-kit": "^0.31.8",
    "prettier": "^3.8.3",
    "typescript": "^5.8.3",
    "vite": "^7.2.4"
  }
}
